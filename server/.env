# server/.env — 環境變數（不要提交到 git！）
# 基礎設定
PORT=3000
JWT_SECRET=haru-jp-dev-secret-change-in-production

# 外部 API Key（目前 Jisho 不需要 key，NHK Easy 也是公開 API）
# 若未來使用付費 API，在此設定
# JISHO_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here

# CORS 允許的前端來源（逗號分隔多個）
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001
